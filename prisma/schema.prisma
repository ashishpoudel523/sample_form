generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Gender {
  male
  female
  other
}

model User {
  id        Int      @id @default(autoincrement())
  username  String
  email     String   @unique
  password  String
  address   String
  phone     String
  gender    Gender
  createdAt DateTime @default(now())
}
